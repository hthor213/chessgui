node_modules/
dist/
__pycache__/
*.pyc
apps/desktop/src-tauri/target/
.env
.env.*
*.log
.DS_Store
*.bin

# Engine binaries (downloaded, not vendored)
engines/

# Stockfish sidecar binaries fetched at build time by
# scripts/fetch-stockfish-sidecar.sh (sha256-pinned, spec 222)
apps/desktop/src-tauri/binaries/

# Raw opening books (large, downloaded — regenerate via scripts/tag_positions.py)
data/openings/

# Reference-database staging: downloaded dumps + filtered packs + stats +
# scratch import DBs (large, re-generated via scripts/build_reference_pack.py).
# Only README.md under data/reference/ is tracked.
data/reference/*
!data/reference/README.md
*.sqlite
*.pgn.zst

# Next.js build output + TS incremental state (generated)
.next/
tsconfig.tsbuildinfo

# WASM engine assets staged by apps/web/scripts/prepare-engine.mjs (the
# worker sf-worker.js next to them IS tracked — only these are generated)
apps/web/public/engine/sf16-7.js
apps/web/public/engine/sf16-7.wasm
apps/web/public/engine/*.nnue

# Vendored third-party lichess-bot checkout (not part of the app)
lichess-bot/

# Agent worktrees (session tooling)
.claude/worktrees/
data/rivals/
data/personas/_cache/
