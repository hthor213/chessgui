{
  "identifier": "default",
  "description": "Default capabilities for ChessGUI",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "clipboard-manager:allow-read-image",
    "clipboard-manager:allow-read-text",
    "clipboard-manager:allow-write-text",
    "shell:allow-spawn",
    "shell:allow-stdin-write",
    "shell:allow-kill",
    "shell:allow-open",
    {
      "identifier": "shell:default",
      "allow": [
        {
          "name": "stockfish",
          "cmd": "",
          "args": true
        }
      ]
    }
  ]
}
